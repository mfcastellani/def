// JSONPlaceholder API module
// Functions return the raw response so the caller can inspect and assert.

def base_url as const string("https://jsonplaceholder.typicode.com")
def title    as const string("Def Language Post")

def create_post as function() (
  def now        as datetime
  def started_at as string(now.format("hh:mm:ss dd/mm/yyyy"))
  def user_id    as string("1")

  request(POST)
    .path(concat(base_url, "/posts"))
    .body_from("jdef/post.jdef")
    .with_var(title)
    .with_var(user_id)
    .with_var(started_at)
    .snapshot()
    .do()
)

def get_post as function(id as string) (
  def res as response(request(GET)
    .path(concat(base_url, "/posts/", id))
    .headers_from("hdef/common.hdef")
    .snapshot()
    .do()
  )

  res.assert_snapshot()
  res  
)

def list_posts as function(user_id as string) (
  request(GET)
    .path(concat(base_url, "/posts"))
    .query_string(tuple("userId", user_id))
    .headers_from("hdef/common.hdef")
    .snapshot()
    .do()
)

def delete_post as function(id as string) (
  request(DELETE)
    .path(concat(base_url, "/posts/", id))
    .headers_from("hdef/common.hdef")
    .snapshot()
    .do()
)
