def ok as boolean(true)

def sum as function(a as integer, b as integer) (
  a + b
)

assert(ok == true)
assert(sum(1, 2) == 3)
assert(12 > 10)
assert(true != false)
assert(10 <= 12)
assert(12 >= 10)
assert(10 < 12)
assert(true and true)
assert(false and false)
assert(true or false)
assert(false or true)

