// Function return values
// Functions do not use a 'return' keyword. The last evaluated expression in
// the function body is implicitly the return value. Here, 'a + b' is that
// last expression, so sum(10, 12) evaluates to 22.

def sum as function(a as integer, b as integer) (
  a + b
)

def n as integer(sum(10, 12))

print("sum(10, 12) = {{n}}")

assert(n == 22)
print("all assertions passed")
