// Plain-text request body with template substitution
// .body_from("file.tdef") loads the request body from a .tdef file and sets
// Content-Type: text/plain automatically.
// .with_var(variable) registers a variable for {{variable}} substitution in
// the body template.
//
// tdef/body.tdef contains raw text with {{language}} placeholder.

def language as string("Def")

// First request: language == "Def"
def res as response(
  request(POST)
    .path("https://httpbingo.org/anything")
    .body_from("tdef/body.tdef")
    .with_var(language)
    .do()
)

def search as string("language")
print("status:        {{res.status()}}")
print("ok:            {{res.ok()}}")
print("duration:      {{res.duration()}}ms")
print("size:          {{res.size()}} bytes")
print("content-type:  {{res.content_type()}}")
print("body contains '{{search}}': {{res.body_contains(search)}}")
print("body:          {{res.body()}}")

// Second request: inner scope shadows 'language' for this request only.
def res_with_var as response(
  def language as string("Def Language")

  request(POST)
    .path("https://httpbingo.org/anything")
    .body_from("tdef/body.tdef")
    .with_var(language)
    .do()
)

def search as string("Def Language")
print("status:        {{res_with_var.status()}}")
print("ok:            {{res_with_var.ok()}}")
print("duration:      {{res_with_var.duration()}}ms")
print("size:          {{res_with_var.size()}} bytes")
print("content-type:  {{res_with_var.content_type()}}")
print("body contains '{{search}}': {{res_with_var.body_contains(search)}}")
print("body:          {{res_with_var.body()}}")
